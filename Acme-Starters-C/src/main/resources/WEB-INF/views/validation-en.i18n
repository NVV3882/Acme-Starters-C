# validation-en.i18n

acme.validation.header.message = Must have between 1 and 75 characters
acme.validation.text.message = Must have between 1 and 255 characters
acme.validation.ticker.message = The reference must follow this pattern: XX00-AAAAA (two uppercase letters, two digits, a hyphen, and 5 to 10 alphanumeric characters)

acme.validation.sponsorship.duplicated-ticker.message = Reference already in use
acme.validation.sponsorship.publicado-sin-donaciones.message = A sponsorship cannot be published without at least one donation
acme.validation.sponsorship.intervalo-correcto-tiempo.message = The sponsorship start and end moments must define a valid future time interval
acme.validation.sponsorship.suma-donaciones-correctas.message = The total sponsorship amount must match the sum of its donations
acme.validation.sponsorship.son-donaciones-en-euros.message = All donations of a sponsorship must be in euros


acme.validation.Invention.duplicated-ticker.message  = The ticker is already in use
acme.validation.invention.published-without-parts.message = The Invention must have 1 part minimum
acme.validation.invention.incorrect-dates-intervale.message = The startMoment of a Invention must be before the endMoment
acme.validation.invention.currency.message = The application only accept money with the currency Euros